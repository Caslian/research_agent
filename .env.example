# InnoCore AI 环境配置示例文件
# 复制此文件为 .env 并修改相应的值

# ============================================
# LLM 配置
# ============================================
# OpenAI API 配置（如果使用 OpenAI）
OPENAI_API_KEY=sk-712aef04c8a84adcad6c66c305f39fef
OPENAI_BASE_URL=https://ws-lkfwi8pizyr0770t.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.7-max

# 阿里云灵积配置（如果使用 Qwen 系列模型，推荐）
# DASHSCOPE_API_KEY=your_dashscope_api_key
# LLM_MODEL=qwen-plus

# ModelScope 配置
# MODELSCOPE_API_KEY=your_modelscope_api_key
# LLM_MODEL=qwen/Qwen2.5-7B-Instruct

# 通用 LLM 配置（推荐用下面两个通用变量）
LLM_BASE_URL=${OPENAI_BASE_URL}
LLM_MODEL=${OPENAI_MODEL}

# Embedding 配置
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=sk-712aef04c8a84adcad6c66c305f39fef
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
